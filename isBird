import os
from ultralytics import YOLO
import cv2

#scp /home/athom/runs/detect/train/weights/best.pt pi@raspberrypi.local:/home/pi/

#Load trained YOLOv8 model
model = YOLO('homepi/best.pt')


print("Fine-Tuned model loaded successfully")

def isBird(image_path: str) -> bool:
    #detects if the object in the image is a bird using YOLO and COCO class
    #returns True if prediction confidence > 60%, else False
    results = model.predict(source=image_path, conf=0.25, verbose=False)
    for r in results:
        for box in r.boxes:
            cls_id = int(box.cls[0])
            conf = float(box.conf[0])
            label = model.names[cls_id].lower()
            if "bird" in label and conf >= 0.60:
                return True
    return False

def test_folder(folder_path: str):
    #loops through all iamges in folder and prints whether a bird is detected
    supported_exts = (".jpg", ".jpeg", ".png", ".bmp")
    for isBirdFolder in os.listdir(folder_path):
        if isBirdFolder.lower().endswith(supported_exts):
            image_path = os.path.join(folder_path, isBirdFolder)
            result = isBird(image_path)
            print(f"{isBirdFolder}: {'Bird Detected ' if result else 'No Bird'}")

if __name__ == "__main__":
    test_folder("C:/Users/athom/OneDrive/Pictures/isBirdFolder")

